			"hidden": true,
			"generator": "Ninja",
			"toolchainFile": "CMake/Toolchains/Windows-x64-msvc.cmake",
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		},
		{
			"name": "Windows-x64-msvc-Debug",
			"displayName": "Windows x64 MSVC - Debug",
