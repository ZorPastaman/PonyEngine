{
	"version": 9,
	"configurePresets": [
		{
			"name": "Base",
			"hidden": true,
			"binaryDir": "${sourceDir}/Output/Build/${presetName}",
			"installDir": "${sourceDir}/Output/Install/${presetName}"
		},
		{
			"name": "Debug",
			"inherits": "Base",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"PONY_GAME_OPTIMAZATION": "Debug",
				"PONY_ENGINE_OPTIMIZATION": "Debug"
			}
		},
		{
			"name": "Development",
			"inherits": "Base",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"PONY_GAME_OPTIMAZATION": "Debug",
				"PONY_ENGINE_OPTIMIZATION": "Release"
			}
		},
		{
			"name": "Release",
			"inherits": "Base",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "RelWithDebInfo",
				"PONY_GAME_OPTIMAZATION": "Release",
				"PONY_ENGINE_OPTIMIZATION": "Release"
			}
		},
		{
			"name": "Shipping",
			"inherits": "Base",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"PONY_GAME_OPTIMAZATION": "Release",
				"PONY_ENGINE_OPTIMIZATION": "Release"
			}
		},
		{
			"name": "WinCore",
			"hidden": true,
			"cacheVariables": {
				"PONY_WINCORE": "TRUE"
			}
		},
		{
			"name": "Windows",
			"inherits": "WinCore",
			"hidden": true,
			"cacheVariables": {
				"PONY_WINDOWS": "TRUE"
			},
			"architecture": {
				"value": "x64",
				"strategy": "external"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		},
		{
			"name": "Windows-Debug",
			"inherits": [ "Debug", "Windows" ]
		},
		{
			"name": "Windows-Development",
			"inherits": [ "Development", "Windows" ]
		},
		{
			"name": "Windows-Release",
			"inherits": [ "Release", "Windows" ]
		},
		{
			"name": "Windows-Shipping",
			"inherits": [ "Shipping", "Windows" ]
		}
	]
}
