{
	"version": 9,
	"configurePresets": [
		{
			"name": "Base",
			"hidden": true,
			"binaryDir": "${sourceDir}/Output/Build/${presetName}",
			"installDir": "${sourceDir}/Output/Install/${presetName}",
			"cacheVariables": {
				"PONY_COMPANY_NAME": "PonyEngine",
				"PONY_PROJECT_NAME": "PonyEngineGame",
				"PONY_PROJECT_VERSION": "0.0.0.0",
				"PONY_CONSOLE_LOG": "TRUE",
				"PONY_ENGINE_LOG_EXT": "TRUE",
				"PONY_ENGINE_LOG_IMPL": "TRUE",
				"PONY_ENGINE_LOG_CORE": "TRUE",
				"PONY_ENGINE_LOG_CONSOLE": "TRUE",
				"PONY_ENGINE_LOG_FILE": "TRUE",
				"PONY_ENGINE_LOG_FILE_PATH": "Logs/Log.log",
				"PONY_ENGINE_LOG_CONSOLE_ORDER": "10",
				"PONY_ENGINE_LOG_FILE_ORDER": "50",
				"PONY_ENGINE_ENGINE_EXT": "TRUE",
				"PONY_ENGINE_ENGINE_IMPL": "TRUE",
				"PONY_ENGINE_APPLICATION": "TRUE",
				"PONY_ENGINE_ADD_GAME": "TRUE",
				"PONY_ENGINE_TESTING": "TRUE"
			}
		},
		{
			"name": "Debug",
			"inherits": "Base",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"PONY_GAME_OPTIMIZATION": "Debug",
				"PONY_ENGINE_OPTIMIZATION": "Debug",
				"PONY_GAME_LOG_LEVEL": "Debug",
				"PONY_ENGINE_LOG_LEVEL": "Debug",
				"PONY_GAME_LOG_STACKTRACE_LEVEL": "Error",
				"PONY_ENGINE_LOG_STACKTRACE_LEVEL": "Error"
			}
		},
		{
			"name": "Development",
			"inherits": "Base",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"PONY_GAME_OPTIMIZATION": "Debug",
				"PONY_ENGINE_OPTIMIZATION": "Release",
				"PONY_GAME_LOG_LEVEL": "Debug",
				"PONY_ENGINE_LOG_LEVEL": "Info",
				"PONY_GAME_LOG_STACKTRACE_LEVEL": "Error",
				"PONY_ENGINE_LOG_STACKTRACE_LEVEL": "Exception"
			}
		},
		{
			"name": "Release",
			"inherits": "Base",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "RelWithDebInfo",
				"PONY_GAME_OPTIMIZATION": "Release",
				"PONY_ENGINE_OPTIMIZATION": "Release",
				"PONY_GAME_LOG_LEVEL": "Info",
				"PONY_ENGINE_LOG_LEVEL": "Warning",
				"PONY_GAME_LOG_STACKTRACE_LEVEL": "Exception",
				"PONY_ENGINE_LOG_STACKTRACE_LEVEL": "Exception",
				"PONY_ENGINE_FORCE_STATIC": "TRUE"
			}
		},
		{
			"name": "Shipping",
			"inherits": "Base",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"PONY_GAME_OPTIMIZATION": "Release",
				"PONY_ENGINE_OPTIMIZATION": "Release",
				"PONY_GAME_LOG_LEVEL": "Error",
				"PONY_ENGINE_LOG_LEVEL": "Error",
				"PONY_GAME_LOG_STACKTRACE_LEVEL": "Exception",
				"PONY_ENGINE_LOG_STACKTRACE_LEVEL": "Exception",
				"PONY_ENGINE_FORCE_STATIC": "TRUE"
			}
		},
		{
			"name": "WinCore",
			"hidden": true,
			"cacheVariables": {
				"PONY_PLATFORM_CONSOLE_LOG": "TRUE",
				"PONY_ENGINE_LOG_PLATFORM_CONSOLE": "TRUE",
				"PONY_ENGINE_LOG_PLATFORM_CONSOLE_ORDER": "20"
			}
		},
		{
			"name": "Windows",
			"inherits": "WinCore",
			"hidden": true,
			"toolchainFile": "CMake/Toolchains/Windows.cmake",
			"architecture": {
				"value": "x64",
				"strategy": "external"
			},
			"toolset": {
				"value": "v143",
				"strategy": "external"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		},
		{
			"name": "Windows-Debug",
			"inherits": [ "Debug", "Windows" ],
			"cacheVariables": {
				"PONY_ENGINE_CREATE_CONSOLE" : "TRUE"
			}
		},
		{
			"name": "Windows-Development",
			"inherits": [ "Development", "Windows" ],
			"cacheVariables": {
				"PONY_ENGINE_CREATE_CONSOLE": "TRUE"
			}
		},
		{
			"name": "Windows-Release",
			"inherits": [ "Release", "Windows" ]
		},
		{
			"name": "Windows-Shipping",
			"inherits": [ "Shipping", "Windows" ]
		}
	]
}
